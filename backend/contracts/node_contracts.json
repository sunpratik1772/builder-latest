      "ports": {
        "inputs": [],
        "outputs": [
          {
            "name": "output",
            "type": "object",
            "description": "Trigger data with timestamp",
            "optional": false
          }
        ]
      },
      "params": [
        {
          "name": "mode",
          "type": "string",
          "description": "Schedule mode",
          "required": true,
          "widget": "text",
          "default": "interval",
          "enum": [
            "interval",
            "cron"
          ]
        },
        {
          "name": "interval",
          "type": "integer",
          "description": "Interval in minutes (interval mode)",
          "required": false,
          "widget": "number",
          "default": 60
        },
        {
          "name": "cron_expression",
          "type": "string",
          "description": "Cron expression (cron mode)",
          "required": false,
          "widget": "text"
        }
      ]
    },
