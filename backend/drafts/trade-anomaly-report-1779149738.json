{
  "schema_version": "1.0",
  "workflow_id": "copilot-1779149738",
  "name": "Trade Anomaly Report",
  "version": "1.0",
  "description": "Pulls trade data, scores anomalies using AI, and generates a summary report.",
  "nodes": [
    {
      "id": "n1",
      "type": "manual_trigger",
      "label": "Start Workflow",
      "config": {},
      "position": {
        "x": 60,
        "y": 280
      }
    },
    {
      "id": "n2",
      "type": "csv_extract",
      "label": "Extract Trade Data",
      "config": {
        "source": "transactions.csv"
      },
      "position": {
        "x": 320,
        "y": 280
      }
    },
    {
      "id": "n3",
      "type": "agent",
      "label": "Score Anomalies",
      "config": {
        "prompt": "Given the transaction details, score the anomaly level from 0 (no anomaly) to 100 (severe anomaly). Consider merchant, category, amount, and type.",
        "task": "Return only a number representing the anomaly score.",
        "perRow": true,
        "outputColumn": "anomaly_score",
        "maxRows": 20
      },
      "position": {
        "x": 600,
        "y": 280
      }
    },
    {
      "id": "n4",
      "type": "agent",
      "label": "Generate Anomaly Report",
      "config": {
        "prompt": "You are a financial analyst. Analyze the provided transaction data, which now includes an 'anomaly_score'. Identify key trends, summarize the most significant anomalies, and suggest potential reasons or impacts. The report should be concise and professional.",
        "task": "Generate a comprehensive anomaly report.",
        "perRow": false
      },
      "position": {
        "x": 600,
        "y": 480
      }
    },
    {
      "id": "n5",
      "type": "response",
      "label": "Return Report",
      "config": {
        "content": "{{rows}}"
      },
      "position": {
        "x": 900,
        "y": 480
      }
    }
  ],
  "edges": [
    {
      "from": "n1",
      "to": "n2"
    },
    {
      "from": "n2",
      "to": "n3"
    },
    {
      "from": "n3",
      "to": "n4"
    },
    {
      "from": "n4",
      "to": "n5"
    }
  ]
}