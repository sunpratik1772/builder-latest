{
  "schema_version": "1.0",
  "workflow_id": "copilot-1779148479",
  "name": "Trade Anomaly Report",
  "version": "1.0",
  "description": "Pulls trade data, identifies transactions with unusually high amounts as anomalies, and generates an Excel report of these anomalies.",
  "nodes": [
    {
      "id": "n1",
      "type": "manual_trigger",
      "label": "Start Workflow",
      "config": {},
      "position": {
        "x": 60,
        "y": 280
      }
    },
    {
      "id": "n2",
      "type": "csv_extract",
      "label": "Extract Trade Data",
      "config": {
        "source": "transactions.csv"
      },
      "position": {
        "x": 320,
        "y": 280
      }
    },
    {
      "id": "n3",
      "type": "code",
      "label": "Score Anomalies",
      "config": {
        "code": "import pandas as pd\ndf = pd.DataFrame(rows)\n# Calculate a simple anomaly threshold: mean + 2 standard deviations\nmean_amount = df['amount'].mean()\nstd_amount = df['amount'].std()\nanomaly_threshold = mean_amount + (2 * std_amount)\n# Flag transactions where amount exceeds the threshold\ndf['is_anomaly'] = df['amount'] > anomaly_threshold\nrows = df.to_dict(orient='records')"
      },
      "position": {
        "x": 600,
        "y": 280
      }
    },
    {
      "id": "n4",
      "type": "filter",
      "label": "Filter Anomalies",
      "config": {
        "expression": "row.is_anomaly === true"
      },
      "position": {
        "x": 600,
        "y": 480
      }
    },
    {
      "id": "n5",
      "type": "excel_output",
      "label": "Write Anomaly Report",
      "config": {
        "filename": "trade_anomaly_report.xlsx",
        "tabNames": [
          "Anomalous Transactions"
        ]
      },
      "position": {
        "x": 900,
        "y": 380
      }
    }
  ],
  "edges": [
    {
