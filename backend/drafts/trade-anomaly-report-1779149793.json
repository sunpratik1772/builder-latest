{
  "schema_version": "1.0",
  "workflow_id": "copilot-1779149793",
  "name": "Trade Anomaly Report",
  "version": "1.0",
  "description": "Pulls trade data, scores anomalies using AI, and generates a CSV report.",
  "nodes": [
    {
      "id": "n1",
      "type": "manual_trigger",
      "label": "Start",
      "config": {},
      "position": {
        "x": 60,
        "y": 280
      }
    },
    {
      "id": "n2",
      "type": "csv_extract",
      "label": "Extract Trade Data",
      "config": {
        "source": "transactions.csv"
      },
      "position": {
        "x": 320,
        "y": 280
      }
    },
    {
      "id": "n3",
      "type": "agent",
      "label": "Score Anomalies",
      "config": {
        "prompt": "Score trade anomalies 0-100.",
        "task": "Return only a number.",
        "perRow": true,
        "outputColumn": "anomaly_score",
        "maxRows": 10
      },
      "position": {
        "x": 600,
        "y": 180
      }
    },
    {
      "id": "n4",
      "type": "csv_output",
      "label": "Generate Anomaly Report CSV",
      "config": {
        "filename": "anomaly_report.csv"
      },
      "position": {
        "x": 600,
        "y": 380
      }
    },
    {
      "id": "n5",
      "type": "response",
      "label": "Return Report",
      "config": {
        "content": "csv"
      },
      "position": {
        "x": 900,
        "y": 280
      }
    }
  ],
  "edges": [
    {
      "from": "n1",
      "to": "n2"
    },
    {
      "from": "n2",
      "to": "n3"
    },
    {
      "from": "n3",
      "to": "n4"
    },
    {
      "from": "n4",
      "to": "n5",
      "sourceHandle": "csv"
    }
  ]
}