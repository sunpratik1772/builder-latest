{
  "schema_version": "1.0",
  "workflow_id": "copilot-1779149387",
  "name": "Trade Data Anomaly Report",
  "version": "1.0",
  "description": "Pulls trade data, identifies and scores anomalies, and generates an Excel report.",
  "nodes": [
    {
      "id": "n1",
      "type": "manual_trigger",
      "label": "Start Workflow",
      "config": {},
      "position": {
        "x": 60,
        "y": 280
      }
    },
    {
      "id": "n2",
      "type": "csv_extract",
      "label": "Extract Trade Data",
      "config": {
        "source": "transactions.csv"
      },
      "position": {
        "x": 320,
        "y": 280
      }
    },
    {
      "id": "n3",
      "type": "filter",
      "label": "Filter High-Value Transactions",
      "config": {
        "expression": "row.amount > 5000"
      },
      "position": {
        "x": 600,
        "y": 180
      }
    },
    {
      "id": "n4",
      "type": "evaluator",
      "label": "Score Anomalies",
      "config": {
        "criteria": "row.amount > 10000",
        "label": "CriticalAnomaly"
      },
      "position": {
        "x": 600,
        "y": 380
      }
    },
    {
      "id": "n5",
      "type": "excel_output",
      "label": "Generate Trade Report",
      "config": {
        "filename": "TradeAnomalyReport.xlsx",
        "tabNames": "All Transactions,Anomalies"
      },
      "position": {
        "x": 900,
        "y": 280
      }
    }
  ],
  "edges": [
    {
      "from": "n1",
      "to": "n2"
    },
    {
      "from": "n2",
      "to": "n3"
    },
    {
      "from": "n3",
      "to": "n4"
    },
    {
      "from": "n2",
      "to": "n5"
    },
    {
      "from": "n4",
      "to": "n5"
    }
  ]
}