    {
      "id": "n02_mock_crm_data",
      "type": "CODE",
      "label": "Mock CRM Data",
      "config": {
        "language": "pythonNative",
        "pythonCode": "import pandas as pd\ncrm_data = [\n    {\"lead_id\": \"L001\", \"company\": \"Alpha Corp\", \"revenue\": 1000000, \"industry\": \"Tech\"},\n    {\"lead_id\": \"L002\", \"company\": \"Beta Inc\", \"revenue\": 500000, \"industry\": \"Finance\"},\n    {\"lead_id\": \"L003\", \"company\": \"Gamma Ltd\", \"revenue\": 200000, \"industry\": \"Retail\"},\n    {\"lead_id\": \"L004\", \"company\": \"Delta Co\", \"revenue\": 1500000, \"industry\": \"Tech\"},\n    {\"lead_id\": \"L005\", \"company\": \"Epsilon LLC\", \"revenue\": 300000, \"industry\": \"Healthcare\"},\n]\noutput_items = crm_data"
      }
    },
    {
      "id": "n03_mock_web_events",
      "type": "CODE",
      "label": "Mock Web Events",
      "config": {
        "language": "pythonNative",
        "pythonCode": "import pandas as pd\nweb_events = [\n    {\"lead_id\": \"L001\", \"event_type\": \"demo_request\", \"timestamp\": \"2023-10-26T10:00:00Z\"},\n    {\"lead_id\": \"L001\", \"event_type\": \"page_view\", \"timestamp\": \"2023-10-26T09:50:00Z\"},\n    {\"lead_id\": \"L002\", \"event_type\": \"whitepaper_download\", \"timestamp\": \"2023-10-25T14:30:00Z\"},\n    {\"lead_id\": \"L003\", \"event_type\": \"page_view\", \"timestamp\": \"2023-10-24T11:00:00Z\"},\n    {\"lead_id\": \"L004\", \"event_type\": \"demo_request\", \"timestamp\": \"2023-10-26T11:15:00Z\"},\n    {\"lead_id\": \"L004\", \"event_type\": \"pricing_page_view\", \"timestamp\": \"2023-10-26T11:05:00Z\"},\n    {\"lead_id\": \"L005\", \"event_type\": \"blog_read\", \"timestamp\": \"2023-10-23T16:00:00Z\"},\n]\noutput_items = web_events"
      }
    },
    {
      "id": "n04_merge_lead_data",
      "type": "MERGE",
      "label": "Merge Lead Data",
      "config": {
        "mode": "combine",
        "combine_by": "matchingFields",
        "fields_to_match": [
          {
            "input1": "lead_id",
            "input2": "lead_id"
          }
        ],
        "output_type": "enrich_input_1"
      }
    },
    {
      "id": "n05_score_leads",
      "type": "CODE",
      "label": "Score Leads",
      "config": {
        "language": "pythonNative",
        "pythonCode": "import pandas as pd\n\nscored_leads = []\nfor item in items:\n    lead = item.json\n    score = 0\n\n    # Score based on revenue\n    if lead.get(\"revenue\", 0) > 1000000:\n        score += 50\n    elif lead.get(\"revenue\", 0) > 500000:\n        score += 30\n    else:\n        score += 10\n\n    # Score based on web events (if available)\n    if 'web_events' in lead and isinstance(lead['web_events'], list):\n        for event in lead['web_events']:\n            if event.get(\"event_type\") == \"demo_request\":\n                score += 40\n            elif event.get(\"event_type\") == \"pricing_page_view\":\n                score += 20\n            elif event.get(\"event_type\") == \"whitepaper_download\":\n                score += 15\n            elif event.get(\"event_type\") == \"page_view\":\n                score += 5\n\n    lead[\"lead_score\"] = score\n    if score >= 80:\n        lead[\"lead_category\"] = \"hot\"\n    elif score >= 40:\n        lead[\"lead_category\"] = \"warm\"\n    else:\n        lead[\"lead_category\"] = \"cold\"\n    scored_leads.append(lead)\n\noutput_items = scored_leads"
      }
    },
    {
      "id": "n06_split_leads",
      "type": "SWITCH",
      "label": "Split Leads by Category",
      "config": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={$json.lead_category}",
                    "rightValue": "hot",
                    "operator": {
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={$json.lead_category}",
                    "rightValue": "warm",
                    "operator": {
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "conditions": {
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={$json.lead_category}",
                    "rightValue": "cold",
                    "operator": {
                      "operation": "equals"
                    }
                  }
                ]
              }
            }
          ]
        },
        "number_of_outputs": 3,
        "fallback_output": "none"
      }
    },
